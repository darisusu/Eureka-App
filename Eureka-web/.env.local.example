# Supabase — project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SECRET_KEY=eyJ...   # service_role key — server-side only, never expose client-side

# Stripe — Dashboard > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # or pk_test_... for dev
STRIPE_SECRET_KEY=sk_live_...                     # or sk_test_... for dev

# Stripe webhook signing secret — Dashboard > Developers > Webhooks > your endpoint
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional — defaults to sgd
# STRIPE_CURRENCY=sgd
